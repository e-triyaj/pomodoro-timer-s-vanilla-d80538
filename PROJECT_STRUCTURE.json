{
  "project": {
    "name": "pomodoro-timer-vanilla",
    "displayName": "Pomodoro Timer S Vanilla",
    "description": "A focus timer with classic Pomodoro intervals (25-minute work sessions, 5-minute short breaks, and 15-minute long breaks) with session tracking and statistics.",
    "version": "1.0.0",
    "type": "fullstack-web-application",
    "category": "productivity",
    "complexity": "medium",
    "estimatedDevelopmentTime": "2-3 weeks",
    "techStack": {
      "frontend": {
        "framework": "React",
        "version": "18.x",
        "language": "JavaScript/TypeScript",
        "bundler": "Vite",
        "styling": "CSS Modules"
      },
      "backend": {
        "framework": "FastAPI",
        "version": "0.110.x",
        "language": "Python",
        "pythonVersion": "3.11+",
        "orm": "SQLAlchemy"
      },
      "database": {
        "primary": "PostgreSQL",
        "version": "15.x",
        "migrationTool": "Alembic"
      }
    }
  },
  "structure": {
