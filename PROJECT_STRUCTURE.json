        }
      }
    }
  },
  "features": {
    "core": [
      {
        "id": "pomodoro-timer",
        "name": "Pomodoro Timer",
        "description": "25-minute work sessions with countdown",
        "priority": "critical"
      },
      {
        "id": "short-break",
        "name": "Short Break Timer",
        "description": "5-minute short break after each work session",
        "priority": "critical"
      },
      {
        "id": "long-break",
        "name": "Long Break Timer",
        "description": "15-minute long break after 4 work sessions",
        "priority": "high"
      },
      {
        "id": "timer-controls",
        "name": "Timer Controls",
        "description": "Start, pause, resume, reset, and skip controls",
        "priority": "critical"
      },
      {
        "id": "auto-transition",
        "name": "Auto Transition",
        "description": "Automatically transition between work and break sessions",
        "priority": "high"
      },
      {
        "id": "audio-notifications",
        "name": "Audio Notifications",
        "description": "Sound alerts when timer completes",
        "priority": "high"
      },
      {
        "id": "browser-notifications",
        "name": "Browser Notifications",
        "description": "Desktop notifications using Notification API",
        "priority": "medium"
      }
    ],
    "secondary": [
      {
        "id": "session-tracking",
        "name": "Session Tracking",
        "description": "Track completed pomodoros and persist to database",
        "priority": "high"
      },
      {
        "id": "statistics",
        "name": "Statistics Dashboard",
        "description": "View daily, weekly, and monthly productivity stats",
        "priority": "medium"
      },
      {
        "id": "custom-settings",
        "name": "Customizable Intervals",
        "description": "Allow users to customize work and break durations",
        "priority": "medium"
      },
      {
        "id": "task-labeling",
        "name": "Task Labels",
        "description": "Label sessions with task descriptions",
        "priority": "low"
      }
    ]
  },
  "api": {
    "baseUrl": "/api/v1",
    "endpoints": [
      {
        "path": "/sessions",
        "methods": ["GET", "POST"],
        "description": "List and create pomodoro sessions"
      },
      {
        "path": "/sessions/{id}",
        "methods": ["GET", "PATCH", "DELETE"],
        "description": "Manage individual sessions"
      },
      {
        "path": "/stats/daily",
        "methods": ["GET"],
        "description": "Get daily statistics"
      },
      {
        "path": "/stats/weekly",
        "methods": ["GET"],
        "description": "Get weekly statistics"
      },
      {
        "path": "/settings",
        "methods": ["GET", "PUT"],
        "description": "Get and update user settings"
      },
      {
        "path": "/health",
        "methods": ["GET"],
        "description": "Health check endpoint"
      }
    ]
  },
  "database": {
    "tables": [
      {
        "name": "sessions",
        "columns": [
          "id (UUID, PK)",
          "session_type (ENUM: work, short_break, long_break)",
          "duration_seconds (INTEGER)",
          "started_at (TIMESTAMP)",
          "completed_at (TIMESTAMP)",
          "task_label (VARCHAR, nullable)",
          "completed (BOOLEAN)",
          "created_at (TIMESTAMP)"
        ]
      },
      {
        "name": "user_settings",
        "columns": [
          "id (UUID, PK)",
          "work_duration (INTEGER, default 1500)",
          "short_break_duration (INTEGER, default 300)",
          "long_break_duration (INTEGER, default 900)",
          "sessions_until_long_break (INTEGER, default 4)",
          "auto_start_breaks (BOOLEAN)",
          "auto_start_pomodoros (BOOLEAN)",
          "sound_enabled (BOOLEAN)",
          "updated_at (TIMESTAMP)"
        ]
      }
    ]
  },
  "deployment": {
    "containerization": {
      "tool": "Docker",
      "compose": true,
      "services": ["frontend", "backend", "postgres"]
    },
    "environments": [
      {
        "name": "development",
        "frontend": "http://localhost:5173",
        "backend": "http://localhost:8000",
        "database": "localhost:5432"
      },
      {
        "name": "production",
        "frontend": "Vercel/Netlify",
        "backend": "Railway/Render/Fly.io",
        "database": "Managed PostgreSQL (Supabase/Neon)"
      }
    ],
    "cicd": {
      "platform": "GitHub Actions",
      "stages": ["lint", "test", "build", "deploy"]
    }
  },
  "scripts": {
    "frontend": {
      "dev": "vite",
      "build": "vite build",
      "preview": "vite preview",
      "lint": "eslint src"
    },
    "backend": {
      "dev": "uvicorn app.main:app --reload",
      "start": "uvicorn app.main:app --host 0.0.0.0 --port 8000",
      "test": "pytest",
      "migrate": "alembic upgrade head"
    }
  },
  "qualityAssurance": {
    "testing": {
      "frontend": ["Vitest", "React Testing Library"],
      "backend": ["pytest", "httpx"]
    },
    "linting": {
      "frontend": ["ESLint", "Prettier"],
      "backend": ["ruff", "black", "mypy"]
    }
  }
}